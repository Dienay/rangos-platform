# =====================================================
# Application
# APP_ENV: development, testing, staging, production
# =====================================================

APP_NAME=Rangos API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080

# =====================================================
# Database
# =====================================================

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rangos

# =====================================================
# Security
# =====================================================

JWT_SECRET_KEY=SUA_CHAVE_SECRETA_MUITO_SEGURA_PARA_DEV_CHANGE_IN_PROD
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# =====================================================
# CORS
# =====================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =====================================================
# Uploads
# =====================================================

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

# =====================================================
# Logging
# =====================================================

LOG_LEVEL=INFO